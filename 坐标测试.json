    {
      "parameters": {
        "jsCode": "// 存储转换后的 OpenAI 格式结果\nconst convertedResults = [];\n\n// 遍历所有输入项，转换为 OpenAI 格式并收集结果\nfor (const item of $input.all()) {\n  // 1. 提取当前项的原始配置数据\n  const config = item.json;\n  \n  // 2. 转义 system 内容中的换行符（解决 JSON 解析错误）\n  const systemContent = config.system ? config.system.replace(/\\n/g, '\\\\n') : '';\n  \n  // 3. 构建 user.content 数组（文本指令 + 多图片链接）\n  const userContent = [];\n  // 添加用户文本指令\n  if (config.user) {\n    userContent.push({\n      \"type\": \"text\",\n      \"text\": config.user\n    });\n  }\n  \n  // 遍历图片链接，添加到 user.content 中\n  if (config.files && Array.isArray(config.files)) {\n    config.files.forEach(url => {\n      userContent.push({\n        \"type\": \"image_url\",\n        \"image_url\": {\n          \"url\": url,\n          \"detail\": \"high\" // 高细节模式适配数学公式识别\n        }\n      });\n    });\n  }\n  \n  // 4. 组装 OpenAI 标准格式\n  const openAIFormat = {\n    \"model\": config.model_name || \"Nanonets-OCR-s-4096\",\n    \"messages\": [\n      {\n        \"role\": \"system\",\n        \"content\": systemContent\n      },\n      {\n        \"role\": \"user\",\n        \"content\": userContent.length > 0 ? userContent : [{\"type\": \"text\", \"text\": \"识别图片内容\"}]\n      }\n    ],\n    \"max_tokens\": 4096,\n    \"temperature\": 0.1\n  };\n  \n  // 5. 将转换后的格式加入结果数组\n  convertedResults.push(openAIFormat);\n}\n\n// 直接返回转换后的 OpenAI 格式结果（无输入项结构）\n// 若只有单个输入项，可返回 convertedResults[0]；多个则返回数组\nreturn convertedResults.length === 1 ? convertedResults[0] : convertedResults;"
      },
