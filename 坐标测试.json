    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'branch' to the JSON of each one\nfor (const item of $input.all()) {\n  // 定义文科科目列表\n  const liberalArtsSubjects = ['语文', '英语', '地理', '政治', '历史','社会'];\n  \n  // 基于准确路径读取科目名称（补充.json层级，适配你的数据结构）\n  // 增加空值判断，避免字段缺失导致报错\n  const subjectName = item.json?.body?.length > 0 \n    ? item.json.body[0].subject_name \n    : '';\n  \n  // 判定文理科（默认理科）\n  const branch = liberalArtsSubjects.includes(subjectName) ? '文科' : '理科';\n  \n  // 将branch字段添加到subject_name同层级（body[0]中）\n  if (item.json?.body?.length > 0) {\n    item.json.body[0].branch = branch;\n  }\n}\n\n// 返回处理后的所有输入项\nreturn $input.all();"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
